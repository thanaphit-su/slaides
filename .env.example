# Backend (apps/api)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:54322/postgres
DATABASE_POOL_SIZE=3
DATABASE_MAX_OVERFLOW=1
DATABASE_POOL_TIMEOUT=10
JWT_SECRET=change-me-in-prod-a-long-random-string
# Signs SLAIDES guest tokens (audience sessions). MUST differ from JWT_SECRET
# in production so a leak of one does not compromise the other.
GUEST_JWT_SECRET=change-me-in-prod-a-different-long-random-string
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
CORS_ORIGINS=http://localhost:5173
REDIS_URL=redis://localhost:6379/0
SESSION_AUDIENCE_CAP=500
SUPABASE_URL=http://localhost:54321
# Leave these empty for the local Docker Compose Supabase stack; the backend
# loads docker/supabase/.env.slaides automatically when DATABASE_URL uses :54322.
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_ISSUER=http://localhost:54321/auth/v1

# Frontend (apps/web)
VITE_API_URL=http://localhost:8000/api/v1

# Production Docker Compose
SLAIDES_DOMAIN=yourdomain.com
